<Window x:Class="Vanilla_RTX_App.Modules.PackBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Vanilla_RTX_App.Modules"
        Title="Browse Packs">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid>

        <!-- Light-theme tint overlay -->
        <Border x:Name="LightThemeOverlay"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False"
                Visibility="{ThemeResource LightThemeBackgroundVisibility}"
                Canvas.ZIndex="-1">
            <Border.Background>
                <SolidColorBrush Color="#20373737" />
            </Border.Background>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             LOADING SCREEN
        ════════════════════════════════════════════════════ -->
        <Grid x:Name="LoadingPanel"
              Visibility="Visible"
              Background="Transparent">
            <ProgressRing IsActive="True"
                          Width="100"
                          Height="100" />
        </Grid>

        <!-- ═══════════════════════════════════════════════════
             MAIN PANEL (title bar + scrollable content)
        ════════════════════════════════════════════════════ -->
        <Grid x:Name="PackSelectionPanel"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <!-- Custom title-bar drag area -->
                <RowDefinition Height="32" />
                <!-- Everything else            -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── Title Bar ───────────────────────────────── -->
            <Grid Grid.Row="0"
                  x:Name="TitleBarArea"
                  Background="Transparent">
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <TextBlock x:Name="WindowTitle"
                               Text=""
                               Margin="0,0,0,0"
                               VerticalAlignment="Center"
                               IsTextScaleFactorEnabled="False"
                               IsHitTestVisible="False" />
                </Grid>
            </Grid>

            <!-- ── Content area ────────────────────────────── -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <!-- Announcements (PSA cards, auto-height) -->
                    <RowDefinition Height="Auto" />
                    <!-- Pack list (scrollable)                 -->
                    <RowDefinition Height="*" />
                    <!-- Bottom action bar (confirm + import)   -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Shadow receiver sits behind everything -->
                <Grid x:Name="ShadowReceiverGrid"
                      Grid.Row="1" />

                <!-- PACK LIST (scrollable) -->
                <ScrollViewer Grid.Row="1"
                              Padding="16,0,16,0"
                              IsTextScaleFactorEnabled="False"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="5,0,5,0">

                    <!-- Wrap both panels in a single parent StackPanel -->
                    <StackPanel>

                        <!-- PSA / announcement cards -->
                        <StackPanel x:Name="PackBrowserAnnouncementsPanel"
                                    Spacing="12"
                                    Margin="0,8,0,8" />

                        <!-- Pack list -->
                        <StackPanel x:Name="PackListContainer"
                                    Spacing="4"
                                    Padding="0,0,0,8" />

                    </StackPanel>
                </ScrollViewer>

                <!-- Empty state overlays the scroll area -->
                <StackPanel x:Name="EmptyStatePanel"
                            Grid.Row="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed"
                            Spacing="12">
                    <FontIcon Glyph="&#xE7C3;"
                              FontSize="48"
                              IsTextScaleFactorEnabled="False"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock x:Name="EmptyStateText"
                               Text="You don't seem to have any resource pack installed! Begin importing your packs here, or install Vanilla RTX from the main menu."
                               FontSize="14"
                               IsTextScaleFactorEnabled="False"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- ══════════════════════════════════════════
                     BOTTOM ACTION BAR
                ═══════════════════════════════════════════ --> 
                <Border Grid.Row="2"
                        Margin="20,5,20,16"
                        CornerRadius="5,5,5,5"
                        BorderThickness="0"
                        Translation="0,0,512"
                        Background="Transparent">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>

                    <Grid Padding="0,0,0,0"
                          MinHeight="92"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <!-- Select All -->
                            <ColumnDefinition Width="70" />
                            <!-- Gap 6 px -->
                            <ColumnDefinition Width="6" />
                            <!-- Confirm -->
                            <ColumnDefinition Width="1.8*" />
                            <!-- Gap 6 px -->
                            <ColumnDefinition Width="6" />
                            <!-- Import -->
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <DropDownButton x:Name="SelectAll_Button"
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        BorderThickness="0"
                                        CornerRadius="5,0,0,5"
                                        IsTextScaleFactorEnabled="False"
                                        ToolTipService.ToolTip="Select all by tag or deselect all">
                            <Grid>
                                <FontIcon x:Name="SelectAllButton_Glyph"
                                          Glyph="&#xE762;"
                                          FontSize="20"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="5,0,0,0"
                                          IsTextScaleFactorEnabled="False" />
                                <TextBlock x:Name="SelectAllButton_Text"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,0"
                                           Visibility="Collapsed"
                                           IsTextScaleFactorEnabled="False" />
                            </Grid>
                        </DropDownButton>

                        <!-- ── CONFIRM SELECTION ──────────────────── -->
                        <Button x:Name="ConfirmButton"
                                Grid.Column="2"
                                Click="ConfirmButton_Click"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                BorderThickness="0"
                                CornerRadius="0,0,0,0"
                                IsTextScaleFactorEnabled="False"
                                ToolTipService.ToolTip="Confirm selection and return to main menu">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="12">
                                <FontIcon Glyph="&#xE8FB;"
                                          FontSize="20"
                                          VerticalAlignment="Center"
                                          IsTextScaleFactorEnabled="False" />
                                <TextBlock Text="Confirm selection"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           IsTextScaleFactorEnabled="False" />
                            </StackPanel>
                        </Button>

                        <!-- ── IMPORT MORE RESOURCE PACKS ────────── -->
                        <Button x:Name="AddPackButton"
                                Grid.Column="4"
                                Click="AddPackButton_Click"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                CornerRadius="0,5,5,0"
                                BorderThickness="0"
                                IsTextScaleFactorEnabled="False"
                                ToolTipService.ToolTip="Allows you to import your resource packs in bulk, supports .zip and .mcpacks formats, multiple packs bundled inside .mcaddon, as well as bulk import from packs inside a folder.">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="12">
                                    <FontIcon Glyph="&#xE896;"
                                              FontSize="20"
                                              VerticalAlignment="Center"
                                              IsTextScaleFactorEnabled="False" />
                                    <TextBlock Text="Import more resource packs"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               IsTextScaleFactorEnabled="False" />
                                </StackPanel>
                                <TextBlock x:Name="AddPackDescriptionText"
                                           FontSize="11"
                                           Opacity="0.67"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           IsTextScaleFactorEnabled="False" />
                            </StackPanel>
                        </Button>

                        <!-- ── BEVELLED SPLIT SEAM 1 ────────────────── -->
                        <Grid Grid.Column="0"
                              HorizontalAlignment="Right"
                              Width="3"
                              Margin="0,0,-3,0"
                              IsHitTestVisible="False">
                            <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                            <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                                    BorderThickness="3,0,0,0" />
                        </Grid>

                        <Grid Grid.Column="2"
                              HorizontalAlignment="Left"
                              Width="3"
                              Margin="-3,0,0,0"
                              IsHitTestVisible="False">
                            <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                            <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                                    BorderThickness="3,0,0,0" />
                        </Grid>
                        <!-- ── BEVELLED SPLIT SEAM 2 ────────────────── -->
                        <Grid Grid.Column="2"
                              HorizontalAlignment="Right"
                              Width="3"
                              Margin="0,0,-3,0"
                              IsHitTestVisible="False">
                            <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                            <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                                    BorderThickness="3,0,0,0" />
                        </Grid>

                        <Grid Grid.Column="4"
                              HorizontalAlignment="Left"
                              Width="3"
                              Margin="-3,0,0,0"
                              IsHitTestVisible="False">
                            <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                            <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                                    BorderThickness="3,0,0,0" />
                        </Grid>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>

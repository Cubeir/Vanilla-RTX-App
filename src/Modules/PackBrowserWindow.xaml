<Window x:Class="Vanilla_RTX_App.PackBrowser.PackBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Vanilla_RTX_App.PackBrowser"
        Title="Browse Packs">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid>

        <!-- Light-theme tint overlay -->
        <Border x:Name="LightThemeOverlay"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False"
                Visibility="{ThemeResource LightThemeBackgroundVisibility}"
                Canvas.ZIndex="-1">
            <Border.Background>
                <SolidColorBrush Color="#17373737" />
            </Border.Background>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             LOADING SCREEN
        ════════════════════════════════════════════════════ -->
        <Grid x:Name="LoadingPanel"
              Visibility="Visible"
              Background="Transparent">
            <ProgressRing IsActive="True"
                          Width="100"
                          Height="100" />
        </Grid>

        <!-- ═══════════════════════════════════════════════════
             MAIN PANEL (title bar + scrollable content)
        ════════════════════════════════════════════════════ -->
        <Grid x:Name="PackSelectionPanel"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <!-- Custom title-bar drag area -->
                <RowDefinition Height="35" />
                <!-- Everything else            -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── Title Bar ───────────────────────────────── -->
            <Grid Grid.Row="0"
                  x:Name="TitleBarArea"
                  Background="Transparent">
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <TextBlock x:Name="WindowTitle"
                               Text=""
                               Margin="0,6,0,5"
                               VerticalAlignment="Center"
                               IsTextScaleFactorEnabled="False"
                               IsHitTestVisible="False" />
                </Grid>
            </Grid>

            <!-- ── Content area ────────────────────────────── -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <!-- Announcements (PSA cards, auto-height) -->
                    <RowDefinition Height="Auto" />
                    <!-- Pack list (scrollable)                 -->
                    <RowDefinition Height="*" />
                    <!-- Bottom action bar (confirm + import)   -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- PSA / announcement cards -->
                <StackPanel x:Name="PackBrowserAnnouncementsPanel"
                            Grid.Row="0"
                            Spacing="12"
                            Margin="22,8,22,8" />

                <!-- Shadow receiver sits behind everything -->
                <Grid x:Name="ShadowReceiverGrid"
                      Grid.Row="1" />

                <!-- PACK LIST (scrollable) -->
                <ScrollViewer Grid.Row="1"
                              Padding="20,4,20,0"
                              IsTextScaleFactorEnabled="False"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="PackListContainer"
                                Spacing="8"
                                Padding="0,0,0,8" />
                </ScrollViewer>

                <!-- Empty state overlays the scroll area -->
                <StackPanel x:Name="EmptyStatePanel"
                            Grid.Row="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed"
                            Spacing="12">
                    <FontIcon Glyph="&#xE7C3;"
                              FontSize="48"
                              IsTextScaleFactorEnabled="False"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock x:Name="EmptyStateText"
                               Text="No packs found"
                               FontSize="14"
                               IsTextScaleFactorEnabled="False"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- ══════════════════════════════════════════
                     BOTTOM ACTION BAR — Confirm | Import
                ═══════════════════════════════════════════ -->
                <!-- Bottom Action Bar Shadow Host -->
                <Border x:Name="ActionBarShadowHost"
                        Grid.Row="2"
                        Margin="20,5,20,16"
                        CornerRadius="5,5,5,5"
                        BorderThickness="0"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">

                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>

                    <Grid Padding="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <!-- Select All Button -->
                            <ColumnDefinition Width="0.125*" />
                            <!-- Gap       6 px -->
                            <ColumnDefinition Width="6" />
                            <!-- Confirm  60 % -->
                            <ColumnDefinition Width="1.4*" />
                            <!-- Gap       6 px -->
                            <ColumnDefinition Width="6" />
                            <!-- Import   40 % -->
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <!-- Select All Button -->
                        <Button x:Name="SelectAll_Button"
                                Grid.Column="0"
                                Click="SelectAll_Button_Click"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                MinHeight="100"
                                BorderThickness="0"
                                CornerRadius="5,0,0,5"
                                IsTextScaleFactorEnabled="False"
                                ToolTipService.ToolTip="Select or deselect all">
                            <Button.Shadow>
                                <ThemeShadow />
                            </Button.Shadow>
                            <Grid>
                                <FontIcon x:Name="SelectAllButton_Glyph"
                                          Glyph="&#xECCD;"
                                          FontSize="18"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="0, -3, 0, 0"
                                          IsTextScaleFactorEnabled="False" />
                                <TextBlock x:Name="SelectAllButton_Text"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0, -3, 0, 0"
                                           Visibility="Collapsed"
                                           IsTextScaleFactorEnabled="False" />
                            </Grid>
                        </Button>

                        <!-- ── CONFIRM SELECTION ──────────────────── -->
                        <Button x:Name="ConfirmButton"
                                Grid.Column="2"
                                Click="ConfirmButton_Click"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                MinHeight="100"
                                BorderThickness="0"
                                CornerRadius="0,0,0,0"
                                IsTextScaleFactorEnabled="False">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="12">
                                <FontIcon Glyph="&#xE8FB;"
                                          FontSize="20"
                                          VerticalAlignment="Center"
                                          IsTextScaleFactorEnabled="False" />
                                <TextBlock Text="Confirm selection"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           IsTextScaleFactorEnabled="False" />
                            </StackPanel>
                        </Button>

                        <!-- ── IMPORT MORE RESOURCE PACKS ────────── -->
                        <Button x:Name="AddPackButton"
                                Grid.Column="4"
                                Click="AddPackButton_Click"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                MinHeight="100"
                                CornerRadius="0,5,5,0"
                                BorderThickness="0"
                                IsTextScaleFactorEnabled="False">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="12">
                                    <FontIcon Glyph="&#xE896;"
                                              FontSize="20"
                                              VerticalAlignment="Center"
                                              IsTextScaleFactorEnabled="False" />
                                    <TextBlock Text="Import more resource packs"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               IsTextScaleFactorEnabled="False" />
                                </StackPanel>
                                <TextBlock x:Name="AddPackDescriptionText"
                                           FontSize="12"
                                           Opacity="0.67"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           IsTextScaleFactorEnabled="False" />
                            </StackPanel>
                        </Button>

                        <!-- ── BEVELLED SPLIT SEAM 1 ────────────────── -->
                        <Grid Grid.Column="0"
                              HorizontalAlignment="Right"
                              Width="3"
                              Margin="0,0,-3,0"
                              IsHitTestVisible="False">
                            <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                            <Border BorderBrush="{StaticResource FakeSplitButtonDarkBorderColor}"
                                    BorderThickness="3,0,0,0" />
                        </Grid>

                        <Grid Grid.Column="2"
                              HorizontalAlignment="Left"
                              Width="3"
                              Margin="-3,0,0,0"
                              IsHitTestVisible="False">
                            <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                            <Border BorderBrush="{StaticResource FakeSplitButtonBrightBorderColor}"
                                    BorderThickness="3,0,0,0" />
                        </Grid>
                        <!-- ── BEVELLED SPLIT SEAM 2 ────────────────── -->
                        <Grid Grid.Column="2"
                              HorizontalAlignment="Right"
                              Width="3"
                              Margin="0,0,-3,0"
                              IsHitTestVisible="False">
                            <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                            <Border BorderBrush="{StaticResource FakeSplitButtonDarkBorderColor}"
                                    BorderThickness="3,0,0,0" />
                        </Grid>

                        <Grid Grid.Column="4"
                              HorizontalAlignment="Left"
                              Width="3"
                              Margin="-3,0,0,0"
                              IsHitTestVisible="False">
                            <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                            <Border BorderBrush="{StaticResource FakeSplitButtonBrightBorderColor}"
                                    BorderThickness="3,0,0,0" />
                        </Grid>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>

<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Vanilla_RTX_App.Modules.Alchitex.Alchitex"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Vanilla_RTX_App.Modules.Alchitex"
        Title="RTX Reactor">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <!--  BACKGROUND IMAGE  -->
        <Image x:Name="AlchitexBackground"
               Source="ms-appx:///Modules/Alchitex/Assets/huge_background.png"
               Stretch="None"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               IsHitTestVisible="False"
               CacheMode="BitmapCache"
               Canvas.ZIndex="-2"
               Opacity="1.0">
        </Image>

        <!-- Light theme tint overlay -->
        <Border x:Name="LightThemeOverlay"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False"
                Visibility="{ThemeResource LightThemeBackgroundVisibility}"
                Canvas.ZIndex="-1">
            <Border.Background>
                <SolidColorBrush Color="#17373737" />
            </Border.Background>
        </Border>

        <!-- TITLEBAR -->
        <Grid x:Name="TitleBarHost"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Canvas.ZIndex="100">

            <!-- Titlebar Background -->
            <Border x:Name="TitleBarBackground"
                    Height="38"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="{ThemeResource CardBackgroundFillColorSecondary}"
                    BorderBrush="{ThemeResource HyperlinkButtonBorderThemeBrush}"
                    BorderThickness="0,0,0,6"
                    CornerRadius="0"
                    Translation="0,0,256"
                    IsHitTestVisible="False">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
            </Border>

            <!-- Drag area  -->
            <Border x:Name="TitleBarDragArea"
                    HorizontalAlignment="Stretch"
                    Height="32"
                    VerticalAlignment="Top"
                    Margin="0,0,0,0"
                    Background="Transparent"
                    IsHitTestVisible="False" />

            <!-- Info button -->
            <Button x:Name="InfoButton"
                    Width="40"
                    Height="31"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    CornerRadius="0"
                    Padding="0"
                    Visibility="Collapsed"
                    ToolTipService.ToolTip="Learn more..."
                    Click="InfoButton_Click">
                <FontIcon Glyph="&#xE946;"
                          FontSize="14"
                          IsTextScaleFactorEnabled="False" />
            </Button>

            <!-- Titlebar Content -->
            <Grid x:Name="TitleBarCenterContent"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="0,-7,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo canvas -->
                <Canvas Grid.Column="0"
                        Height="24"
                        Width="24"
                        VerticalAlignment="Center"
                        Margin="0,1,7,0"
                        Canvas.ZIndex="1">

                    <!-- Base image -->
                    <Image x:Name="AlchitexIconBase"
                           Source="ms-appx:///Modules/Alchitex/Assets/logo.small.png"
                           Height="24"
                           Width="24"
                           Canvas.Top="1"
                           Opacity="1.0"
                           Canvas.ZIndex="3"
                           IsHitTestVisible="False" />
                </Canvas>

                <!-- Text -->
                <TextBlock x:Name="TitleBarText"
                           Text="License Agreement"
                           Grid.Column="1"
                           FontSize="14"
                           Margin="0,7,0,4"
                           VerticalAlignment="Center"
                           Canvas.ZIndex="0"
                           FontWeight="Medium"
                           IsTextScaleFactorEnabled="False"
                           IsHitTestVisible="False" />
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  LOADING PANEL                                          -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="LoadingPanel"
              Visibility="Visible"
              Margin="0,35,0,0"
              Background="Transparent">
            <ProgressRing IsActive="True"
                          Width="100"
                          Height="100"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center" />
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  LICENSE PANEL                                          -->
        <!--  Sits BELOW the shared titlebar (Margin top = 35)       -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="LicensePanel"
              Visibility="Collapsed"
              Background="{ThemeResource OverlayBackgroundColor}"
              Padding="16, 0, 16 16"
              Margin="0,36,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <!-- license text  -->
                <RowDefinition Height="Auto" />
                <!-- buttons       -->
            </Grid.RowDefinitions>
            
            <!-- ── License RichTextBlock ── -->
            <ScrollViewer Grid.Row="0"
                          Background="{ThemeResource OverlayBackgroundColor}"
                          Margin="64,32,64,32"
                          MaxWidth="720"
                          BorderBrush="#40FFFFFF"
                          BorderThickness="2"
                          CornerRadius="12"
                          VerticalScrollBarVisibility="Auto">
                <RichTextBlock x:Name="LicenseTextBlock"
                               IsTextSelectionEnabled="False"
                               Padding="24"
                               TextWrapping="Wrap"
                               IsTabStop="False"
                               FontSize="14"
                               LineHeight="20"
                               IsTextScaleFactorEnabled="False"
                               HorizontalAlignment="Center"
                               Translation="0,0,32">
                    <RichTextBlock.Shadow>
                        <ThemeShadow x:Name="LicenseTextShadow" />
                    </RichTextBlock.Shadow>
                    <!-- Populated in code-behind -->
                </RichTextBlock>
            </ScrollViewer>

            <!-- ── Action buttons ── -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="16"
                        Background="Transparent"
                        Margin="0,0,0,24">

                <Button x:Name="DisagreeButton"
                        Padding="16,16,16,16"
                        IsTextScaleFactorEnabled="False"
                        Translation="0,0,32"
                        Click="DisagreeButton_Click"
                        Content="Disagree and close"
                        Style="{ThemeResource ButtonRevealStyle}">
                    <Button.Shadow>
                        <ThemeShadow x:Name="DisagreeShadow" />
                    </Button.Shadow>

                </Button>

                <Button x:Name="AgreeButton"
                        Padding="16,16,16,16"
                        Style="{ThemeResource AccentButtonStyle}"
                        IsTextScaleFactorEnabled="False"
                        Translation="0,0,32"
                        Content="I have read and agreed to the terms and conditions of this feature"
                        Click="AgreeButton_Click">
                    <Button.Shadow>
                        <ThemeShadow x:Name="AgreeShadow" />
                    </Button.Shadow>
                </Button>

            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  MAIN CONTENT GRID (Shown after license accept)         -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="MainGrid"
              Visibility="Collapsed"
              Background="Transparent"
              Margin="0,37,0,0">

            <!-- ── Alchitex feature content area ── -->
            <Border x:Name="AnnouncementBackground"
                    Padding="6"
                    CornerRadius="0"
                    Margin="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
                <Border.Background>
                    <AcrylicBrush TintColor="{ThemeResource OverlayBackgroundColor}"
                                  TintOpacity="0.6"
                                  FallbackColor="{ThemeResource OverlayBackgroundColor}" />
                </Border.Background>

                <!-- PSA / announcement cards -->
                <StackPanel x:Name="AlchitexAnnouncementsPanel"
                            Spacing="12"
                            Margin="24,12,24,12" />
            </Border>
        </Grid>



    </Grid>
</Window>

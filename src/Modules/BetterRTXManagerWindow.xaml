<Window x:Class="Vanilla_RTX_App.Modules.BetterRTXManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Vanilla_RTX_App.Modules"
        Title="BetterRTX Manager">
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>
    <Grid>
        <Border x:Name="LightThemeOverlay"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False"
                Visibility="{ThemeResource LightThemeBackgroundVisibility}"
                Canvas.ZIndex="-1">
            <Border.Background>
                <SolidColorBrush Color="#17373737" />
            </Border.Background>
        </Border>

        <!-- Loading Screen -->
        <Grid x:Name="LoadingPanel"
              Visibility="Visible"
              Background="Transparent">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="20">
                <ProgressRing IsActive="True"
                              Width="100"
                              Height="100" />

                <Button x:Name="ManualSelectionButton"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        Padding="20,12,20,12"
                        Style="{ThemeResource AccentButtonStyle}"
                        Click="ManualSelectionButton_Click">
                    <StackPanel Spacing="10">
                        <TextBlock Text="The app couldn't auto-locate your game files using the usual fast methods!&#x0a;A system-wide scan is in progress, there is a high chance it will find your game given enough time."
                                   FontSize="15"
                                   TextAlignment="Center"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Center"
                                   IsTextScaleFactorEnabled="False" />
                        <TextBlock x:Name="ManualSelectionText"
                                   Text="But if it is taking too long? Click to manually navigate to the folder where the game is installed to, it should have a file called Minecraft.Windows.exe inside of it.
                                   &#x0a;&#x0a;The app is tolerant towards slightly imprecise location selections, it will still try to have a look around no matter where you select, but if you're still having trouble finding out where your game is installed to, join the Vanilla RTX Discord server and ask for help, or try to find out online."
                                   FontSize="13"
                                   Opacity="0.8"
                                   FontWeight="Medium"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"
                                   IsTextScaleFactorEnabled="False" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Preset Selection UI -->
        <Grid x:Name="PresetSelectionPanel"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar Area -->
            <Grid Grid.Row="0"
                  x:Name="TitleBarArea"
                  Background="Transparent">
                <!-- Centered Title -->
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <TextBlock Text=""
                               Margin="0,4,0,0"
                               VerticalAlignment="Center"
                               IsTextScaleFactorEnabled="False"
                               IsHitTestVisible="False"
                               x:Name="WindowTitle" />
                </Grid>
            </Grid>

            <!-- Preset List -->
            <Grid Grid.Row="1">
                <!-- Shadow receiver sits behind the scroll content -->
                <Grid x:Name="ShadowReceiverGrid" />

                <ScrollViewer Padding="20,16,24,0"
                              Margin="0,-4,0,0"
                              IsTextScaleFactorEnabled="False"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <!-- Wrapped both panels in a single parent StackPanel -->
                    <StackPanel>
                        <!-- PSA cards (Horizontal margins removed to avoid duplicating ScrollViewer padding) -->
                        <StackPanel x:Name="BetterRTXAnnouncementsPanel"
                                    Spacing="10"
                                    Margin="0,12,0,14" />
                        <!-- Preset list -->
                        <StackPanel x:Name="PresetListContainer"
                                    Spacing="8" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyStatePanel"
                        Grid.Row="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="Collapsed"
                        Spacing="12">
                <FontIcon Glyph="&#xEABC;"
                          FontSize="50"
                          IsTextScaleFactorEnabled="False"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock x:Name="EmptyStateText"
                           Text="No BetterRTX presets cached"
                           FontSize="14"
                           IsTextScaleFactorEnabled="False"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- Refresh Button -->
        <Button x:Name="RefreshButton"
                Width="52"
                Height="36"
                Margin="32,1,0,0"
                Padding="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                CornerRadius="0, 0, 6, 6"
                Click="RefreshButton_Click"
                Translation="0,0,16"
                IsTextScaleFactorEnabled="False"
                ToolTipService.ToolTip="Resets cache, clearing all downloaded files from BetterRTX API and forcing a new re-fetch.
                &#x0a;&#x0a;Note: This happens automatically whenever Minecraft is updated (always) or periodically whenever changes in the API are detected (possibly, but not guranteed), hence this button exists for you to trigger a manual refresh in case BetterRTX delievers its updates with a delay or the API pretends to remain the same after rolling out updates.
                &#x0a;&#x0a;Note 2: This button won't clear your Default RTX preset, which is backed up upon your first attempt at installing a preset. Only game updates can trigger a reset of Default preset, so that the app can ultimately pick up the new defaults fresh from the new version of your game.">
            <Button.Shadow>
                <ThemeShadow />
            </Button.Shadow>
            <Grid>
                <FontIcon x:Name="RefreshIcon"
                          Glyph="&#xE72C;"
                          FontSize="16"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="0, -3, 0, 0"
                          IsTextScaleFactorEnabled="False" />
                <TextBlock x:Name="RefreshCountdownText"
                           FontSize="14"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0, -3, 0, 0"
                           Visibility="Collapsed"
                           IsTextScaleFactorEnabled="False" />
            </Grid>
        </Button>
    </Grid>
</Window>

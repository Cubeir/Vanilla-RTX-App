<Window x:Class="Vanilla_RTX_App.RTXDefaults.DefaultRTXModifiersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Vanilla_RTX_App.RTXDefaults"
        Title="RTX Lut Manager">
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>
    <Grid>
        <Border x:Name="LightThemeOverlay"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False"
                Visibility="{ThemeResource LightThemeBackgroundVisibility}"
                Canvas.ZIndex="-1">
            <Border.Background>
                <SolidColorBrush Color="#17373737" />
            </Border.Background>
        </Border>

        <!-- Loading Screen -->
        <Grid x:Name="LoadingPanel"
              Visibility="Visible"
              Background="Transparent">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="20">
                <ProgressRing IsActive="True"
                              Width="100"
                              Height="100" />
                <Button x:Name="ManualSelectionButton"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        Padding="20,12,20,12"
                        Click="ManualSelectionButton_Click">
                    <StackPanel Spacing="4">
                        <TextBlock Text="System-wide scan is in progress"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   IsTextScaleFactorEnabled="False" />
                        <TextBlock x:Name="ManualSelectionText"
                                   Text="If this is taking too long, click to manually locate the game folder."
                                   FontSize="12"
                                   Opacity="0.75"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"
                                   IsTextScaleFactorEnabled="False" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main UI -->
        <Grid x:Name="MainPanel"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0"
                  x:Name="TitleBarArea"
                  Background="Transparent">
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <TextBlock x:Name="WindowTitle"
                               Text="RTX look up tables manager"
                               Margin="0,6,0,5"
                               VerticalAlignment="Center"
                               IsTextScaleFactorEnabled="False"
                               IsHitTestVisible="False" />
                </Grid>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <!-- Row 0: Button pair -->
                    <RowDefinition Height="Auto" />
                    <!-- Row 1: Description text -->
                    <RowDefinition Height="Auto" />
                    <!-- Row 2: Preset preview image -->
                    <RowDefinition Height="*" />
                    <!-- Row 3: More desc pains -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ═══════════════════════════════════════════════
                     ROW 0 — Preset dropdown + Install button pair
                     ═══════════════════════════════════════════════ -->

                <Grid x:Name="ButtonShadowReceiver"
                      Grid.Row="0"
                      Height="90"
                      IsHitTestVisible="False" />

                <Grid x:Name="ButtonRowGrid"
                      Grid.Row="0"
                      Height="50"
                      Margin="20,14,20,0"
                      VerticalAlignment="Top"
                      HorizontalAlignment="Stretch"
                      Translation="0,0,32"
                      Loaded="ButtonRowGrid_Loaded">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.15*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <DropDownButton x:Name="SelectPresetMenu"
                                    Grid.Column="0"
                                    Content="Loading..."
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    FontWeight="SemiBold"
                                    CornerRadius="4,0,0,4"
                                    BorderThickness="0"
                                    IsTextScaleFactorEnabled="False"
                                    ToolTipService.ToolTip="Select a LUT preset">
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="Bottom" />
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <Button x:Name="InstallButton"
                            Grid.Column="2"
                            Content="Install"
                            Click="InstallButton_Click"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="0,6,6,0"
                            BorderThickness="0"
                            IsEnabled="False"
                            IsTextScaleFactorEnabled="False"
                            ToolTipService.ToolTip="Install the selected preset." />

                    <!-- Visual split — dark border on right edge of left button -->
                    <Grid Grid.Column="0"
                          HorizontalAlignment="Right"
                          Width="3"
                          Margin="0,0,-3,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                                BorderThickness="3,0,0,0" />
                    </Grid>

                    <!-- Visual split — bright border on left edge of right button -->
                    <Grid Grid.Column="2"
                          HorizontalAlignment="Left"
                          Width="3"
                          Margin="-3,0,0,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                                BorderThickness="3,0,0,0" />
                    </Grid>
                </Grid>

                <!-- ═══════════════════════════════════════════════
                     ROW 1 — Description text
                     ═══════════════════════════════════════════════ -->
                <!-- Info Panel -->
                <Border CornerRadius="8"
                        Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        Padding="16"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Margin="20, -12, 20, 0"
                        Translation="0,0,32">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>


                        <!-- Info & Text -->
                        <FontIcon Grid.Column="0"
                                  Grid.Row="0"
                                  Glyph="&#xE946;"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="18"
                                  VerticalAlignment="Center"
                                  Margin="0,2,12,0"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Grid.Row="0"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Opacity="0.9"
                                   TextAlignment="Left"
                                   VerticalAlignment="Center"
                                   IsTextScaleFactorEnabled="False"
                                   Text="Look up tables provide a simple way to improve or further customize Minecraft RTX, which works across all game versions reliably and without a performance hit as oppposed to heavier modifications such as BetterRTX. Select from the list of available presets and hit install. You can always revert back to defaults by selecting the default preset." />

                        <!-- Static Space -->

                        <!-- Info & Text -->
                        <FontIcon Grid.Column="0"
                                  Grid.Row="2"
                                  Glyph="&#xE946;"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="18"
                                  VerticalAlignment="Center"
                                  Margin="0,2,12,0"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Grid.Row="2"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Opacity="0.9"
                                   TextAlignment="Left"
                                   VerticalAlignment="Center"
                                   IsTextScaleFactorEnabled="False"
                                   Text="This feature will not work if you're using a BetterRTX Preset (Default RTX must be used), additionally, you can learn to create your own lut and submit it to be bundled with the app's future updates!" />
                    </Grid>
                </Border>



                <!-- ═══════════════════════════════════════════════
                     ROW 2 — Preset preview image (crossfade vessels)
                     Bottom vessel: current/settled image
                     Top vessel:    incoming image, fades in over bottom
                     ═══════════════════════════════════════════════ -->
                <Grid Grid.Row="2"
                      Padding="0,16,0,0">

                    <Rectangle Fill="{ThemeResource FakeSplitButtonBrightBorderColor}"
                               Height="6"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Top"
                               Canvas.ZIndex="996"
                               CacheMode="BitmapCache"
                               Opacity="1.0">
                        
                    </Rectangle>
                    <Rectangle Fill="{ThemeResource FakeSplitButtonBrightBorderColor}"
                               Height="3"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Top"
                               Canvas.ZIndex="997"
                               CacheMode="BitmapCache"
                               Opacity="1.0">
                    </Rectangle>

                    
                    <Rectangle Fill="{ThemeResource FakeSplitButtonBrightBorderColor}"
                               Height="3"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Bottom"
                               Canvas.ZIndex="999"
                               CacheMode="BitmapCache"
                               Margin="0, 0, 0, 30"
                               Opacity="0.1">
                    </Rectangle>
                    <HyperlinkButton Content="Learn to create and submit your own lut presets for everyone to see them here!"
                                     NavigateUri="https://github.com/cubeir/Vanilla-RTX-App/main"
                                     Foreground="{StaticResource SystemAccentColorLight3}"
                                     Background="#80000000" 
                                     Padding="6"
                                     CornerRadius="0"
                                     FontSize="14"
                                     VerticalAlignment="Bottom"
                                     HorizontalAlignment="Stretch"
                                     Canvas.ZIndex="998"/>

                    <!-- Bottom vessel — holds the settled (current) image -->
                    <Image x:Name="PresetImageBottom"
                           CacheMode="BitmapCache"
                           Stretch="UniformToFill"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="1" />

                    <!-- Top vessel — fades in the incoming image over the bottom -->
                    <Image x:Name="PresetImageTop"
                           CacheMode="BitmapCache"
                           Stretch="UniformToFill"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0">
                        <Image.Transitions>
                            <TransitionCollection />
                        </Image.Transitions>
                    </Image>
                </Grid>

                
            </Grid>
        </Grid>
    </Grid>
</Window>

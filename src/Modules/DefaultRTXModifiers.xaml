<Window x:Class="Vanilla_RTX_App.RTXDefaults.DefaultRTXModifiersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Vanilla_RTX_App.RTXDefaults"
        Title="Default RTX Modifiers">
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>
    <Grid>
        <Border x:Name="LightThemeOverlay"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False"
                Visibility="{ThemeResource LightThemeBackgroundVisibility}"
                Canvas.ZIndex="-1">
            <Border.Background>
                <SolidColorBrush Color="#17373737" />
            </Border.Background>
        </Border>

        <!-- Loading Screen -->
        <Grid x:Name="LoadingPanel"
              Visibility="Visible"
              Background="Transparent">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="20">
                <ProgressRing IsActive="True"
                              Width="100"
                              Height="100" />
                <Button x:Name="ManualSelectionButton"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        Padding="20,12,20,12"
                        Click="ManualSelectionButton_Click">
                    <StackPanel Spacing="4">
                        <TextBlock Text="System-wide scan is in progress"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   IsTextScaleFactorEnabled="False" />
                        <TextBlock x:Name="ManualSelectionText"
                                   Text="If this is taking too long, click to manually locate the game folder."
                                   FontSize="12"
                                   Opacity="0.75"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"
                                   IsTextScaleFactorEnabled="False" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main UI -->
        <Grid x:Name="MainPanel"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <!-- Title bar -->
                <RowDefinition Height="35" />
                <!-- Content -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0"
                  x:Name="TitleBarArea"
                  Background="Transparent">
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <TextBlock x:Name="WindowTitle"
                               Text="Default RTX Modifiers"
                               Margin="0,6,0,5"
                               VerticalAlignment="Center"
                               IsTextScaleFactorEnabled="False"
                               IsHitTestVisible="False" />
                </Grid>
            </Grid>

            <!-- Content rows -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <!-- Row 0: Install button strip -->
                    <RowDefinition Height="Auto" />
                    <!-- Row 1: Text -->
                    <RowDefinition Height="Auto" />
                    <!-- Row 2: Image -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>


                <!-- ═══════════════════════════════════════════════════════════
                     ROW 0 — Install Preset Dropdown Double Button
                     ═══════════════════════════════════════════════════════════ -->


                <Grid Grid.Row="0"
                      Height="90"
                      VerticalAlignment="Top"
                      Padding="20,12,20,16"
                      CornerRadius="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.25*" />
                        <!-- 6px gap between buttons -->
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <DropDownButton x:Name="SelectPresetMenu"
                                    Grid.Column="0"
                                    Content="Selected lut preset: Default"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    FontWeight="SemiBold"
                                    CornerRadius="4,0,0,4"
                                    BorderThickness="0"
                                    IsTextScaleFactorEnabled="False"
                                    ToolTipService.ToolTip="Select a LUT preset">
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuFlyoutItem Text="Default"
                                                Click="SelectPresetMenu_Click" />
                                <MenuFlyoutItem Text="Example Preset"
                                                Click="SelectPresetMenu_Click" />
                                <MenuFlyoutItem Text="Example Preset 2"
                                                Click="SelectPresetMenu_Click" />
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>


                    <Button x:Name="InstallButton"
                            Grid.Column="2"
                            Content="Install preset"
                            Click="InstallButton_Click"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="0,6,6,0"
                            BorderThickness="0"
                            IsTextScaleFactorEnabled="False"
                            ToolTipService.ToolTip="Install the selected preset.">
                    </Button>

                    <!-- Overlay borders for the visual split -->
                    <!-- Dark border on RIGHT edge of left button -->
                    <Grid Grid.Column="0"
                          HorizontalAlignment="Right"
                          Width="3"
                          Margin="0,0,-3,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                                BorderThickness="3,0,0,0" />
                    </Grid>

                    <!-- Bright border on LEFT edge of right button -->
                    <Grid Grid.Column="2"
                          HorizontalAlignment="Left"
                          Width="3"
                          Margin="-3,0,0,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                                BorderThickness="3,0,0,0" />
                    </Grid>
                </Grid>
                
                <!-- ═══════════════════════════════════════════════════════════
                     ROW 1 — Text
                     ═══════════════════════════════════════════════════════════ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <!-- Text -->
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <!-- Text -->
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>


                    <StackPanel Grid.Column="0"
                                Padding="20,8,20,8"
                                VerticalAlignment="Center"
                                Spacing="10">
                        <TextBlock x:Name="Description"
                                   Text="This tool provides a simple, reliable way of customizing and improving Minecraft RTX's visuals through LUTs (look-up-tables), select from the list of available presets and press Install."
                                   FontSize="14"
                                   TextAlignment="Left"
                                   Opacity="1.0"
                                   TextWrapping="Wrap"
                                   IsTextScaleFactorEnabled="False" />
                        <TextBlock x:Name="Description2"
                                   Text="You can always revert back to defaults by installing the Default preset. This tool also won't work if you're using a BetterRTX preset."
                                   FontSize="14"
                                   TextAlignment="Left"
                                   Opacity="0.75"
                                   TextWrapping="Wrap"
                                   IsTextScaleFactorEnabled="False" />
                    </StackPanel>
                </Grid>


                <!-- ═══════════════════════════════════════════════════════════
                     ROW 2 — Image
                     ═══════════════════════════════════════════════════════════ -->
                <Border x:Name="ImageShadowHost"
                        Grid.Row="2"
                        Height="100"
                        VerticalAlignment="Top"
                        Padding="20"
                        CornerRadius="6"
                        Translation="0,0,62">
                    <Border.Shadow>
                        <ThemeShadow x:Name="ImageShadow" />
                    </Border.Shadow>
                </Border>
                
                <Grid Grid.Row="2"
                      Padding="20, 8, 20, 0"
                      VerticalAlignment="Bottom"
                      HorizontalAlignment="Stretch">
                            
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Image Source="ms-appx:///Assets/icons/SplashScreen.Regular.png"
                           Stretch="None"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           NineGrid="10, 10 , 10, 10"/>

                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>

<Window x:Class="Vanilla_RTX_App.RTXDefaults.DefaultRTXModifiersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Vanilla_RTX_App.RTXDefaults"
        Title="Default RTX Modifiers">
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>
    <Grid>
        <Border x:Name="LightThemeOverlay"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False"
                Visibility="{ThemeResource LightThemeBackgroundVisibility}"
                Canvas.ZIndex="-1">
            <Border.Background>
                <SolidColorBrush Color="#17373737" />
            </Border.Background>
        </Border>

        <!-- Loading Screen -->
        <Grid x:Name="LoadingPanel"
              Visibility="Visible"
              Background="Transparent">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="20">
                <ProgressRing IsActive="True"
                              Width="100"
                              Height="100" />
                <Button x:Name="ManualSelectionButton"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        Padding="20,12,20,12"
                        Click="ManualSelectionButton_Click">
                    <StackPanel Spacing="4">
                        <TextBlock Text="System-wide scan is in progress"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   IsTextScaleFactorEnabled="False" />
                        <TextBlock x:Name="ManualSelectionText"
                                   Text="If this is taking too long, click to manually locate the game folder."
                                   FontSize="12"
                                   Opacity="0.75"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"
                                   IsTextScaleFactorEnabled="False" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main UI -->
        <Grid x:Name="MainPanel"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0"
                  x:Name="TitleBarArea"
                  Background="Transparent">
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <TextBlock x:Name="WindowTitle"
                               Text="RTX look up tables manager"
                               Margin="0,6,0,5"
                               VerticalAlignment="Center"
                               IsTextScaleFactorEnabled="False"
                               IsHitTestVisible="False" />
                </Grid>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <!-- Row 0: Button pair -->
                    <RowDefinition Height="Auto" />
                    <!-- Row 1: Description text -->
                    <RowDefinition Height="Auto" />
                    <!-- Row 2: Preset preview image -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ═══════════════════════════════════════════════
                     ROW 0 — Preset dropdown + Install button pair
                     ═══════════════════════════════════════════════ -->

                <Grid x:Name="ButtonShadowReceiver"
                      Grid.Row="0"
                      Height="90"
                      IsHitTestVisible="False" />

                <Grid x:Name="ButtonRowGrid"
                      Grid.Row="0"
                      Height="90"
                      Padding="20,12,20,16"
                      Translation="0,0,32"
                      Loaded="ButtonRowGrid_Loaded">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.25*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <DropDownButton x:Name="SelectPresetMenu"
                                    Grid.Column="0"
                                    Content="Loading..."
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    FontWeight="SemiBold"
                                    CornerRadius="4,0,0,4"
                                    BorderThickness="0"
                                    IsTextScaleFactorEnabled="False"
                                    ToolTipService.ToolTip="Select a LUT preset">
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="Bottom" />
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <Button x:Name="InstallButton"
                            Grid.Column="2"
                            Content="Install"
                            Click="InstallButton_Click"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="0,6,6,0"
                            BorderThickness="0"
                            IsEnabled="False"
                            IsTextScaleFactorEnabled="False"
                            ToolTipService.ToolTip="Install the selected preset." />

                    <!-- Visual split — dark border on right edge of left button -->
                    <Grid Grid.Column="0"
                          HorizontalAlignment="Right"
                          Width="3"
                          Margin="0,0,-3,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                                BorderThickness="3,0,0,0" />
                    </Grid>

                    <!-- Visual split — bright border on left edge of right button -->
                    <Grid Grid.Column="2"
                          HorizontalAlignment="Left"
                          Width="3"
                          Margin="-3,0,0,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                                BorderThickness="3,0,0,0" />
                    </Grid>
                </Grid>

                <!-- ═══════════════════════════════════════════════
                     ROW 1 — Description text
                     ═══════════════════════════════════════════════ -->
                <StackPanel Grid.Row="1"
                            Padding="20,8,20,8"
                            Spacing="10">
                    <TextBlock x:Name="Description"
                               Text="This tool provides a simple, reliable way of customizing and improving Minecraft RTX's visuals through LUTs (look-up-tables), select from the list of available presets and press Install."
                               FontSize="14"
                               TextAlignment="Left"
                               TextWrapping="Wrap"
                               IsTextScaleFactorEnabled="False" />
                    <TextBlock x:Name="Description2"
                               Text="You can always revert back to defaults by installing the Default preset. This tool also won't work if you're using a BetterRTX preset."
                               FontSize="14"
                               TextAlignment="Left"
                               Opacity="0.75"
                               TextWrapping="Wrap"
                               IsTextScaleFactorEnabled="False" />
                </StackPanel>

                <!-- ═══════════════════════════════════════════════
                     ROW 2 — Preset preview image (crossfade vessels)
                     Bottom vessel: current/settled image
                     Top vessel:    incoming image, fades in over bottom
                     ═══════════════════════════════════════════════ -->
                <Grid Grid.Row="2"
                      Padding="20,8,20,20">
                    <!-- Bottom vessel — holds the settled (current) image -->
                    <Image x:Name="PresetImageBottom"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="1" />

                    <!-- Top vessel — fades in the incoming image over the bottom -->
                    <Image x:Name="PresetImageTop"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0">
                        <Image.Transitions>
                            <TransitionCollection />
                        </Image.Transitions>
                    </Image>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>

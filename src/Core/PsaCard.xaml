<UserControl x:Class="Vanilla_RTX_App.Core.PsaCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             PointerEntered="Card_PointerEntered"
             PointerExited="Card_PointerExited"
             IsTextScaleFactorEnabled="false">

    <Border x:Name="CardBorder"
            CornerRadius="8"
            Padding="6"
            Translation="0,0,32"
            Background="Transparent">
        <Border.Shadow>
            <ThemeShadow />
        </Border.Shadow>

        <Grid x:Name="InnerGrid"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Margin="16,8,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon x:Name="GlyphIcon"
                      Grid.Column="0"
                      Glyph="&#xE946;"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      FontSize="20"
                      VerticalAlignment="Top"
                      Margin="0,5,0,0"
                      IsHitTestVisible="False"
                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />

            <TextBlock x:Name="ContentText"
                       Grid.Column="1"
                       TextWrapping="Wrap"
                       FontSize="14"
                       Margin="12,0,0,0"
                       Opacity="1.0"
                       VerticalAlignment="Center"
                       IsTextScaleFactorEnabled="False" />

            <Button x:Name="DismissButton"
                    Grid.Column="2"
                    Visibility="Visible"
                    Opacity="0.0"
                    Width="22"
                    Height="22"
                    Padding="0"
                    VerticalAlignment="Center"
                    Margin="0,0,0,0"
                    Background="{ThemeResource ButtonBackgroundThemeBrush}"
                    BorderThickness="1"
                    Click="DismissButton_Click"
                    ToolTipService.ToolTip="Dismiss forever">
                <FontIcon Glyph="&#xE8BB;"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          Visibility="Visible"
                          Opacity="1.0"
                          FontSize="12"
                          FontFamily="{ThemeResource SymbolThemeFontFamily}" />
            </Button>
        </Grid>
    </Border>
</UserControl>

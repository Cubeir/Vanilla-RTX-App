<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Vanilla_RTX_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Vanilla_RTX_App"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Vanilla RTX App"
        mc:Ignorable="d">
    
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3.72*" />
        </Grid.ColumnDefinitions>

        <!-- Splash Screen -->
        <Grid x:Name="SplashOverlay"
              Visibility="Visible"
              Grid.ColumnSpan="2"
              Canvas.ZIndex="999">
            <Grid.Background>
                <SolidColorBrush Color="{ThemeResource SolidBackgroundFillColorBase}" />
            </Grid.Background>

            <Viewbox HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     Margin="208, 164, 208, 164"
                     Stretch="Uniform">
                <Grid Width="256"
                      Height="256">
                    <!-- Halo - Bottom layer -->
                    <Image x:Name="SplashLampHalo"
                           Source="ms-appx:///Assets/icons/SplashScreen.Halo.png"
                           Width="1280"
                           Height="1280"
                           Margin="-512,-512,-512,-512"
                           Opacity="0.175"
                           Stretch="Uniform"
                           Canvas.ZIndex="1"/>
                    <!-- Base "On" - Middle layer -->
                    <Image x:Name="SplashLamp"
                           Source="ms-appx:///Assets/icons/SplashScreen.Regular.png"
                           Width="192"
                           Height="192"
                           Opacity="1.0"
                           Stretch="Uniform"
                           Translation="0,0,512"
                           Canvas.ZIndex="2">
                        <Image.Shadow>
                            <ThemeShadow />
                        </Image.Shadow>
                    </Image>
                    <!-- Super/Off overlay - Top layer -->
                    <Image x:Name="SplashLampOverlay"
                           Source="ms-appx:///Assets/icons/SplashScreen.Super.png"
                           Width="192"
                           Height="192"
                           Opacity="0.0"
                           Stretch="Uniform"
                           Canvas.ZIndex="3">
                    </Image>
                </Grid>
            </Viewbox>
        </Grid>

        <!-- Light theme tint overlay -->
        <Border x:Name="LightThemeOverlay"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False"
                Visibility="{ThemeResource LightThemeBackgroundVisibility}"
                Canvas.ZIndex="-999">
            <Border.Background>
                <SolidColorBrush Color="#20373737" />
            </Border.Background>
        </Border>

        <!-- Titlebar -->
        <Grid Grid.ColumnSpan="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Height="35">
            
            <!-- Titlebar Background -->
            <Border x:Name="TitleBarBackground"
                    Height="37"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="{ThemeResource CardBackgroundFillColorSecondary}"
                    BorderBrush="{ThemeResource HyperlinkButtonBorderThemeBrush}"
                    BorderThickness="0,0,0,6"
                    CornerRadius="0"
                    Translation="0,0,32"
                    IsHitTestVisible="False">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
            </Border>

            <!-- Transparent drag area: covers whole titlebar except left 200px so your buttons keep receiving clicks -->
            <Border x:Name="TitleBarDragArea"
                    Margin="236,-1,0,0"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Visibility="Visible"
                    BorderThickness="0"
                    Background="Transparent"
                    IsHitTestVisible="False" />
        </Grid>

        <!-- Titlebar Center Content -->
        <Grid Grid.ColumnSpan="2"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0, -2, 0, 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Canvas Grid.Column="0"
                    Height="24"
                    Width="24"
                    VerticalAlignment="Center"
                    Margin="0,1,7,0"
                    Canvas.ZIndex="1">

                <!-- Halo (Bottom layer) -->
                <Image x:Name="iconHaloImageBox"
                       Source="ms-appx:///Assets/vrtx.lamp.halo.png"
                       Height="136"
                       Width="136"
                       Canvas.Left="-55.5"
                       Canvas.Top="-55.5"
                       Opacity="0.25"
                       Canvas.ZIndex="2"
                       IsHitTestVisible="False"/>

                <Image x:Name="iconImageBox"
                       Source="ms-appx:///Assets/vrtx.lamp.on.small.png"
                       Height="24"
                       Width="24"
                       Canvas.Top="1"
                       Opacity="1.0"
                       Canvas.ZIndex="3"
                       Translation="0,0,14"
                       IsHitTestVisible="False">
                    <Image.Shadow>
                        <ThemeShadow />
                    </Image.Shadow>
                </Image>

                <Image x:Name="iconOverlayImageBox"
                       Source="ms-appx:///Assets/vrtx.lamp.off.small.png"
                       Height="24"
                       Width="24"
                       Canvas.Top="1"
                       Opacity="0.0"
                       Canvas.ZIndex="4"
                       IsHitTestVisible="False">
                </Image>

                <!-- Button to make lamp interactive -->
                <Button x:Name="LampInteractionButton"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Canvas.Left="0"
                        Canvas.Top="1"
                        Opacity="0.0"
                        Height="24"
                        Width="24"
                        Canvas.ZIndex="5"
                        CornerRadius="0"
                        ToolTipService.ToolTip="Hold shift and click the lamp to copy the stack trace for debugging."
                        Click="LampInteraction_Click" />
            </Canvas>

            <TextBlock x:Name="TitleBarText"
                       Text="Vanilla RTX App"
                       Grid.Column="1"
                       FontSize="14"
                       Margin="0,7,0,5"
                       VerticalAlignment="Center"
                       Canvas.ZIndex="0"
                       FontWeight="Medium"
                       IsTextScaleFactorEnabled="False"
                       ToolTipService.ToolTip="App Version: Unknown"
                       IsHitTestVisible="True" />
        </Grid>

        <!-- Titlebar Buttons -->
        <Border Margin="-2,-2,16,0"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Height="34"
                Width="Auto">
            <Grid Background="Transparent"
                  BorderBrush="Transparent"
                  BorderThickness="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <!-- Button -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Separator -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Button -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Separator -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Button -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Separator -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Button -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Separator -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Button -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Chat Button -->
                <Button x:Name="ChatButton"
                        Grid.Column="0"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Content="&#xE8F2;"
                        Width="40"
                        Height="35"
                        CornerRadius="0"
                        FontSize="14"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="ChatButton_Click"
                        ToolTipService.ToolTip="Invitation to the Vanilla RTX Discord server."
                        IsTextScaleFactorEnabled="False" />

                <!-- Separator -->
                <Border Grid.Column="1"
                        Width="1"
                        Margin="4,6,4,6"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!-- Info/Help Button -->
                <Button x:Name="HelpButton"
                        Grid.Column="2"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Content="&#xE946;"
                        Width="40"
                        Height="35"
                        CornerRadius="0"
                        FontSize="16"
                        Click="HelpButton_Click"
                        PointerEntered="HelpButton_PointerEntered"
                        PointerExited="HelpButton_PointerExited"
                        ToolTipService.ToolTip="Open documentation"
                        IsTextScaleFactorEnabled="False" />

                <!-- Separator -->
                <Border Grid.Column="3"
                        Width="1"
                        Margin="4,6,4,6"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!-- Donate Button -->
                <Button x:Name="DonateButton"
                        Grid.Column="4"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Content="&#xEB51;"
                        Width="40"
                        Height="35"
                        CornerRadius="0"
                        FontSize="14"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="DonateButton_Click"
                        PointerEntered="DonateButton_PointerEntered"
                        PointerExited="DonateButton_PointerExited"
                        ToolTipService.ToolTip="Buy the developer some coffee, Vanilla RTX is free and continued, help keep it that way!"
                        IsTextScaleFactorEnabled="False" />

                <!-- Separator -->
                <Border Grid.Column="5"
                        Width="1"
                        Margin="4,6,4,6"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!-- Theme Button -->
                <Button x:Name="CycleThemeButton"
                        Grid.Column="6"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Content="&#xEC46;"
                        Width="40"
                        Height="35"
                        CornerRadius="0"
                        FontSize="16"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="CycleThemeButton_Click"
                        ToolTipService.ToolTip="Cycle through theme options:
                        &#x0a;Dark, Light, System (Auto)
                        &#x0a;Default: Dark"
                        IsTextScaleFactorEnabled="False" />

                <!-- Separator -->
                <Border Grid.Column="7"
                        Width="1"
                        Margin="4,6,4,6"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!-- Suspend Previewer Button -->
                <Button x:Name="SuspendPreviewerToggle"
                        Grid.Column="8"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Content="&#xEC12;"
                        Width="40"
                        Height="35"
                        CornerRadius="0"
                        FontSize="16"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="SuspendPreviewerToggle_Click"
                        ToolTipService.ToolTip="Toggle the visual control previews inside the logs area; Don't like 'em? disable 'em."
                        IsTextScaleFactorEnabled="False" />
            </Grid>
        </Border>


        <!-- Browse packs || Preview || Checkboxes -->
        <Border Grid.ColumnSpan="2"
                Margin="16,52,16,0"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Height="42"
                Translation="0,0,32"
                CornerRadius="6">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.33*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="0.66*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="BrowsePacksButton"
                        Grid.Column="0"
                        Click="BrowsePacksButton_Click"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        FontWeight="SemiBold"
                        CornerRadius="6,0,0,6"
                        BorderThickness="0"
                        IsTextScaleFactorEnabled="False"
                        ToolTipService.ToolTip="Select resource packs that you'd want to tune, export, or delete, you can also import more packs into Minecraft from this menu.">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xF78B;"
                                  FontSize="18"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="BrowsePacksButtonText"
                                   Text="{x:Bind PackVM.BrowseButtonLabel, Mode=OneWay}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>


                <!-- VISUAL SPLIT 1 -->
                <Grid Grid.Column="0"
                      HorizontalAlignment="Right"
                      Width="3"
                      Margin="0,0,-3,0"
                      IsHitTestVisible="False">
                    <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                    <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                            BorderThickness="3,0,0,0"
                            x:Name="RightEdgeOfLocateButton"/>
                </Grid>
                <Grid Grid.Column="2"
                      HorizontalAlignment="Left"
                      Width="3"
                      Margin="-3,0,0,0"
                      IsHitTestVisible="False">
                    <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                    <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                            BorderThickness="3,0,0,0"
                            x:Name="LeftEdgeOfTargetPreviewButton" />
                </Grid>


                <ToggleButton x:Name="TargetPreviewToggle"
                              Grid.Column="2"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              FontWeight="SemiBold"
                              CornerRadius="0,0,0,0"
                              BorderThickness="0"
                              Checked="TargetPreviewToggle_Checked"
                              Unchecked="TargetPreviewToggle_Unchecked"
                              IsTextScaleFactorEnabled="False"
                              ToolTipService.ToolTip="If enabled, all functionalities of the app target Minecraft Preview instead of stable Minecraft Release.">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE98F;"
                                  FontSize="17"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="Preview"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>

                <!-- VISUAL SPLIT 2 -->
                <Grid Grid.Column="2"
                      HorizontalAlignment="Right"
                      Width="3"
                      Margin="0,0,-3,0"
                      IsHitTestVisible="False">
                    <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                    <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                            x:Name="RightEdgeOfTargetPreviewButton"
                            BorderThickness="3,0,0,0" />
                </Grid>
                <Grid Grid.Column="4"
                      HorizontalAlignment="Left"
                      Width="3"
                      Margin="-3,0,0,0"
                      IsHitTestVisible="False">
                    <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                    <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                            BorderThickness="3,0,0,0" />
                </Grid>

                
                <!-- Pack Selection Options -->
                <Border Grid.Column="4"
                        Padding="16,4"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderThickness="0"
                        CornerRadius="0,6,6,0"
                        ToolTipService.ToolTip="Select which Vanilla RTX packs to process.&#x0a;&#x0a;If a checkbox isn't selectable, it means that pack currently not installed, begin installing Vanilla RTX resource packs by clicking the Get latest RTX packs button.">
                    <Grid HorizontalAlignment="Stretch"
                          BorderThickness="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.85*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="1.135*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="1.035*" />
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="VanillaRTXCheckBox"
                                  Grid.Column="0"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="8,0,0,0"
                                  Checked="Option_Checked"
                                  Unchecked="Option_Unchecked"
                                  IsEnabled="False">
                            <TextBlock Text="Vanilla RTX"
                                       FontWeight="SemiBold"
                                       Margin="2,1,0,0"
                                       IsTextScaleFactorEnabled="False" />
                        </CheckBox>

                        <AppBarSeparator Grid.Column="1"
                                         VerticalAlignment="Stretch"
                                         Margin="0" />

                        <CheckBox x:Name="NormalsCheckBox"
                                  Grid.Column="2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="8,0,0,0"
                                  Checked="Option_Checked"
                                  Unchecked="Option_Unchecked"
                                  IsEnabled="False">
                            <TextBlock Text="Vanilla RTX Normals"
                                       FontWeight="SemiBold"
                                       Margin="2,1,0,0"
                                       IsTextScaleFactorEnabled="False" />
                        </CheckBox>

                        <AppBarSeparator Grid.Column="3"
                                         VerticalAlignment="Stretch"
                                         Margin="0" />

                        <CheckBox x:Name="OpusCheckBox"
                                  Grid.Column="4"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="8,0,0,0"
                                  Checked="Option_Checked"
                                  Unchecked="Option_Unchecked"
                                  IsEnabled="False">
                            <TextBlock Text="Vanilla RTX Opus"
                                       FontWeight="SemiBold"
                                       Margin="2,1,0,0"
                                       IsTextScaleFactorEnabled="False" />
                        </CheckBox>
                    </Grid>
                </Border>

            </Grid>
        </Border>


        <!-- LEFT CONTENT AREA -->
        <Grid Grid.Column="0"
              x:Name="LeftContentGrid">
            <!-- Sidebar Log Box -->
            <Grid>
                <!-- Textbox -->
                <TextBox x:Name="SidebarLog"
                         Margin="16,108,8,16"
                         VerticalAlignment="Stretch"
                         HorizontalAlignment="Stretch"
                         TextWrapping="Wrap"
                         IsTabStop="False"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         AllowFocusOnInteraction="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Padding="12,12,12,12"
                         Translation="0,0,64"
                         IsTextScaleFactorEnabled="False"
                         ToolTipService.ToolTip="Relevant logs appear here to inform, guide, or warn you as you interact with the app.">
                    <TextBox.Shadow>
                        <ThemeShadow />
                    </TextBox.Shadow>
                </TextBox>
            </Grid>

            <!-- Progress Bar -->
            <ProgressBar x:Name="ProgressBar"
                         Margin="16,108,8,0"
                         VerticalAlignment="Top"
                         HorizontalAlignment="Stretch"
                         IsIndeterminate="False"
                         ShowPaused="False"
                         ShowError="False" />

            <!-- Preview Image Vessels -->
            <Image x:Name="PreviewVesselTop"
                   Width="Auto"
                   Height="150"
                   MaxWidth="{Binding ActualWidth, ElementName=SidebarLog}"
                   Margin="8,0,0,17"
                   Stretch="Uniform"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Center"
                   IsHitTestVisible="False"
                   Canvas.ZIndex="99"
                   Visibility="Collapsed"
                   Opacity="0.0"
                   Source="ms-appx:///Assets/empty.png" />
            <Image x:Name="PreviewVesselBottom"
                   Width="Auto"
                   Height="150"
                   MaxWidth="{Binding ActualWidth, ElementName=SidebarLog}"
                   Margin="8,0,0,17"
                   Stretch="Uniform"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Center"
                   IsHitTestVisible="False"
                   Canvas.ZIndex="98"
                   Visibility="Collapsed"
                   Opacity="0.0"
                   Source="ms-appx:///Assets/empty.png" />
            <Image x:Name="PreviewVesselBackground"
                   Width="Auto"
                   Height="150"
                   Margin="17,0,9,17"
                   Stretch="UniformToFill"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Center"
                   IsHitTestVisible="False"
                   Canvas.ZIndex="97"
                   Visibility="Visible"
                   Opacity="1.0"
                   Source="ms-appx:///Assets/previews/huge_background.png" />
        </Grid>

     
        <!-- RIGHT CONTENT AREA -->
        <Grid Grid.Column="1">
            
            <!-- Main layout grid with defined rows -->
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Sliders Grid -->
                    <RowDefinition Height="Auto" />
                    <!-- Spacing -->
                    <RowDefinition Height="2" />
                    <!-- Tune & Export & Delete Grid -->
                    <RowDefinition Height="Auto" />
                    <!-- Spacing -->
                    <RowDefinition Height="*" />
                    <!-- 3x2 Button Grid -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>



                <!-- =============== Sliders Grid =============== -->
                <Grid x:Name="SlidersGrid"
                      Grid.Row="0"
                      Margin="16,108,24,0"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">

                    <!-- Grid Proportion Definitions -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="20" />
                        <!-- 16px spacing between columns -->
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                    </Grid.RowDefinitions>

                    <!-- (Special) Grid 2 Reset Button with shadow -->
                    <Border Grid.Column="2"
                            Grid.Row="0"
                            Height="40"
                            VerticalAlignment="Bottom"
                            Translation="0,0,32"
                            CornerRadius="6">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                    </Border>

                    <Grid Grid.Column="2"
                          Grid.Row="0"
                          Height="40"
                          VerticalAlignment="Bottom"
                          BorderThickness="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.65*" />
                            <ColumnDefinition Width="6" />
                            <!-- 6px gap between buttons -->
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ClearButton"
                                Grid.Column="0"
                                Click="ClearButton_Click"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                CornerRadius="6,0,0,6"
                                BorderThickness="0"
                                IsTextScaleFactorEnabled="False"
                                ToolTipService.ToolTip="Clears all pack sections.">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xEA99;"
                                          FontSize="16"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="Clear selection"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="ResetButton"
                                Grid.Column="2"
                                Click="ResetButton_Click"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                CornerRadius="0,6,6,0"
                                BorderThickness="0"
                                IsTextScaleFactorEnabled="False"
                                ToolTipService.ToolTip="Default Function: Resets tuning options back to their default values.
                                &#x0a;&#x0a;FOR ADVANCED USERS: Hold shit while pressing to perform a hard reset that wipes all of app's data everywhere, making it as if it was freshly installed.
                                Might also prompt you for reverting back to Default RTX/Default LUT files if needed, so your defaults aren't lost the next time you use the app.">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE777;"
                                          x:Name="ResetButton_FontIcon"
                                          FontSize="16"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="Reset"
                                           x:Name="ResetButton_TextBlock"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Dark bevel on RIGHT edge of left button -->
                        <Grid Grid.Column="0"
                              HorizontalAlignment="Right"
                              Width="3"
                              Margin="0,0,-3,0"
                              IsHitTestVisible="False">
                            <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                            <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                                    BorderThickness="3,0,0,0" />
                        </Grid>

                        <!-- Bright bevel on LEFT edge of right button -->
                        <Grid Grid.Column="2"
                              HorizontalAlignment="Left"
                              Width="3"
                              Margin="-3,0,0,0"
                              IsHitTestVisible="False">
                            <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                            <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                                    BorderThickness="3,0,0,0" />
                        </Grid>
                    </Grid>

                    <!-- Fog Multiplier -->
                    <StackPanel Grid.Column="0"
                                Grid.Row="0"
                                Spacing="2"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="Fog density multiplier"
                                   FontWeight="SemiBold"
                                   IsTextScaleFactorEnabled="False"
                                   ToolTipService.ToolTip="Scales all fog densities with the given multiplier.
                                   &#x0a;&#x0a;Recommended ranges:
                                   &#x0a;0.2–0.8 for lighter fog
                                   &#x0a;1.5-3.0 for dense fog
                                   &#x0a;0.0 to disable air fog
                                   &#x0a;&#x0a;Advanced tip: The value of the multiplier will be treated as, and applied, as a literal density value if fog density is already too small (like 0) to multiply." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Slider room -->
                                <ColumnDefinition Width="*"
                                                  MinWidth="80" />
                                <!-- Spacing -->
                                <ColumnDefinition Width="6" />
                                <!-- TextBox room -->
                                <ColumnDefinition Width="65" />
                            </Grid.ColumnDefinitions>

                            <Slider x:Name="FogMultiplierSlider"
                                    Grid.Column="0"
                                    Minimum="0.0"
                                    Maximum="10.0"
                                    StepFrequency="0.01"
                                    SmallChange="0.01"
                                    Value="1"
                                    ValueChanged="FogMultiplierSlider_ValueChanged" />

                            <TextBox x:Name="FogMultiplierBox"
                                     Grid.Column="2"
                                     Width="60"
                                     Text="1.00"
                                     LostFocus="FogMultiplierBox_LostFocus"
                                     IsTextScaleFactorEnabled="False"
                                    />
                        </Grid>
                    </StackPanel>

                    <!-- Emissivity Multiplier -->
                    <StackPanel Grid.Column="0"
                                Grid.Row="2"
                                Spacing="2"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="Emissive strength multiplier"
                                   FontWeight="SemiBold"
                                   IsTextScaleFactorEnabled="False"
                                   ToolTipService.ToolTip="Scales glowing effects of all emissive blocks. 
                                   &#x0a;&#x0a;Examples:
                                   &#x0a;1 = default
                                   &#x0a;0.5 = half brightness
                                   &#x0a;higher values = stronger glowing effects on blocks." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"
                                                  MinWidth="80" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="65" />
                            </Grid.ColumnDefinitions>

                            <Slider x:Name="EmissivityMultiplierSlider"
                                    Grid.Column="0"
                                    Minimum="0.2"
                                    Maximum="16"
                                    StepFrequency="0.1"
                                    SmallChange="0.1"
                                    Value="1"
                                    ValueChanged="EmissivityMultiplierSlider_ValueChanged" />

                            <TextBox x:Name="EmissivityMultiplierBox"
                                     Grid.Column="2"
                                     Width="60"
                                     Text="1.0"
                                     IsTextScaleFactorEnabled="False"
                                     LostFocus="EmissivityMultiplierBox_LostFocus" />
                        </Grid>
                    </StackPanel>

                    <!-- Emissivity Ambient Light Toggle -->
                    <StackPanel Grid.Column="0"
                                Grid.Row="4"
                                Spacing="2"
                                VerticalAlignment="Center">
                        <TextBlock Text="Increase ambient lighting"
                                   FontWeight="SemiBold"
                                   IsTextScaleFactorEnabled="False"
                                   ToolTipService.ToolTip="Modifies ambient lighting when emissivity is adjusted, higher emissive multipliers strengthen the effect.
                                   &#x0a;&#x0a;Note: Applying this option to a resource pack will block Emissive multiplier from being applied to that resource pack ever again unless the resource pack is reset/reintalled freshly." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"
                                                  MinWidth="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ToggleSwitch x:Name="EmissivityAmbientLightToggle"
                                          Grid.Column="0"
                                          AutomationProperties.Name="Emissivity Ambient Light Toggle"
                                          Toggled="EmissivityAmbientLightToggle_Toggled"
                                          IsTextScaleFactorEnabled="False"
                                          VerticalAlignment="Top" />
                            <TextBlock x:Name="EmissivityWarningIcon"
                                       Style="{ThemeResource TextBlockSegIcons}"
                                       Grid.Column="1"
                                       Text="&#xE7BA;"
                                       FontSize="36"
                                       VerticalAlignment="Top"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,14,0"
                                       Visibility="Collapsed"
                                       IsTextScaleFactorEnabled="False"
                                       ToolTipService.ToolTip="Enabling this option while tuning a resource pack will cause future tuning attempts to skip applying the Emissivity Multiplier slider to that pack, this intentional guardrail keeps PBR from appearing broken.
                                       &#x0a;Furthermore, this option is intended for RTX resource packs only, do not enable for Vibrant Visuals resource packs. Use this option sparingly or as the last step in tuning a resource pack to your taste." />
                        </Grid>
                    </StackPanel>

                    <!-- Normal Intensity -->
                    <StackPanel Grid.Column="0"
                                Grid.Row="6"
                                Spacing="2"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="Surface normal intensity"
                                   FontWeight="SemiBold"
                                   IsTextScaleFactorEnabled="False"
                                   ToolTipService.ToolTip="Adjust intensity of normal maps and heightmaps in percentage, if available.
                                   &#x0a;&#x0a;0% = flattens all textures
                                   &#x0a;100% = default (no change)
                                   &#x0a;Higher values = stronger 3D effects on surfaces."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"
                                                  MinWidth="80" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="65" />
                            </Grid.ColumnDefinitions>

                            <Slider x:Name="NormalIntensitySlider"
                                    TickFrequency="90"
                                    TickPlacement="Inline"
                                    SnapsTo="StepValues"
                                    Grid.Column="0"
                                    Minimum="0"
                                    Maximum="900"
                                    StepFrequency="1"
                                    SmallChange="1"
                                    Value="100"
                                    ValueChanged="NormalIntensity_ValueChanged" />

                            <TextBox x:Name="NormalIntensityBox"
                                     Grid.Column="2"
                                     Width="60"
                                     Text="100"
                                     LostFocus="NormalIntensity_LostFocus"
                                     IsTextScaleFactorEnabled="False"/>
                        </Grid>
                    </StackPanel>

                    <!-- Material Grain Offset -->
                    <StackPanel Grid.Column="2"
                                Grid.Row="2"
                                Spacing="2"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="Material grain offset"
                                   FontWeight="SemiBold"
                                   IsTextScaleFactorEnabled="False"
                                   ToolTipService.ToolTip="Adds additional detail to PBR textures and reduces uniformity by adding a layer of noise in a manner that keeps the pack's intended look intact.
                                   &#x0a;Your input determines the maximum possible deviation from the original values." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"
                                                  MinWidth="80" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="65" />
                            </Grid.ColumnDefinitions>

                            <Slider x:Name="MaterialNoiseSlider"
                                    TickFrequency="5"
                                    TickPlacement="BottomRight"
                                    SnapsTo="StepValues"
                                    Grid.Column="0"
                                    Minimum="0"
                                    Maximum="64"
                                    StepFrequency="1"
                                    SmallChange="1"
                                    Value="0"
                                    ValueChanged="MaterialNoise_ValueChanged" />

                            <TextBox x:Name="MaterialNoiseBox"
                                     Grid.Column="2"
                                     Width="60"
                                     Text="0"
                                     LostFocus="MaterialNoise_LostFocus"
                                     IsTextScaleFactorEnabled="False"/>
                        </Grid>
                    </StackPanel>

                    <!-- Roughen Up -->
                    <StackPanel Grid.Column="2"
                                Grid.Row="4"
                                Spacing="2"
                                VerticalAlignment="Center">
                        <TextBlock Text="Roughness control"
                                   FontWeight="SemiBold"
                                   IsTextScaleFactorEnabled="False"
                                   ToolTipService.ToolTip="Adjusts overall balance of roughness and metalness of materials.
                                   &#x0a;&#x0a;Higher values result in overall fewer glossy surfaces and metallic metals
                                   &#x0a;Negative values strengthen glossy or metallic surfaces.
                                   &#x0a;Uses a smart decaying curve to impact values that are relevant, keeping a resource pack's intended look intact." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"
                                                  MinWidth="80" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="65" />
                            </Grid.ColumnDefinitions>

                            <Slider x:Name="RoughenUpSlider"
                                    TickFrequency="5"
                                    TickPlacement="BottomRight"
                                    SnapsTo="StepValues"
                                    Grid.Column="0"
                                    Minimum="-16"
                                    Maximum="48"
                                    StepFrequency="1"
                                    SmallChange="1"
                                    Value="0"
                                    ValueChanged="RoughenUp_ValueChanged" />

                            <TextBox x:Name="RoughenUpBox"
                                     Grid.Column="2"
                                     Width="60"
                                     Text="0"
                                     LostFocus="RoughenUp_LostFocus"
                                     IsTextScaleFactorEnabled="False"/>
                        </Grid>
                    </StackPanel>

                    <!-- Butcher Heightmaps -->
                    <StackPanel Grid.Column="2"
                                Grid.Row="6"
                                Spacing="2"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="Lazify surface normals"
                                   FontWeight="SemiBold"
                                   IsTextScaleFactorEnabled="False"
                                   ToolTipService.ToolTip="Lazifies heightmaps and normal maps by reducing refinedness.
                                   &#x0a;&#x0a;0 = no change
                                   &#x0a;255 = fully lazy
                                   &#x0a;Reresource packs that are already shoddy might see no change or even slight improvements, while higher quality packs can receive an additional layer of detail, for which a small value under 20 is generally recommended." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"
                                                  MinWidth="80" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="65" />
                            </Grid.ColumnDefinitions>

                            <Slider x:Name="LazifyNormalsSlider"
                                    TickFrequency="3"
                                    TickPlacement="Inline"
                                    SnapsTo="StepValues"
                                    Grid.Column="0"
                                    Minimum="0"
                                    Maximum="255"
                                    StepFrequency="1"
                                    SmallChange="1"
                                    Value="0"
                                    ValueChanged="LazifyNormals_ValueChanged" />

                            <TextBox x:Name="LazifyNormalsBox"
                                     Grid.Column="2"
                                     Width="60"
                                     Text="0"
                                     LostFocus="LazifyNormals_LostFocus"
                                     IsTextScaleFactorEnabled="False"
                                      />
                        </Grid>
                    </StackPanel>
                </Grid>
                <!-- =============== End of Sliders Grid =============== -->

                <!-- Tune | Export | Delete button block -->
                <Border Grid.Row="2"
                        Margin="16,0,24,0"
                        Height="43"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        CornerRadius="6"
                        BorderThickness="0"
                        Translation="0,0,32">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                </Border>

                <Grid Grid.Row="2"
                      Margin="16,0,24,0"
                      Height="43"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Top"
                      BorderThickness="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="0.33*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="44" />
                    </Grid.ColumnDefinitions>

                    <!-- Tune Button -->
                    <Button x:Name="TuneSelectionButton"
                            Click="TuneSelectionButton_Click"
                            Grid.Row="0"
                            Grid.Column="0"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="6,0,0,6"
                            BorderThickness="0"
                            IsTextScaleFactorEnabled="False"
                            ToolTipService.ToolTip="Begins permanently modifying all selected packs using the current set parameters.&#x0a;&#x0a;Make sure Minecraft is closed while packs are being tuned.">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <FontIcon x:Name="TuneSelectionButtonIcon"
                                      Glyph="&#xE9F5;"
                                      FontSize="18"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center" />
                            <TextBlock x:Name="TuneSelectionButtonText"
                                       Text="Tune selection"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <!-- Export Selection Button -->
                    <Button x:Name="ExportButton"
                            Click="ExportButton_Click"
                            Grid.Row="0"
                            Grid.Column="2"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="0,0,0,0"
                            BorderThickness="0"
                            IsTextScaleFactorEnabled="False"
                            ToolTipService.ToolTip="Exports selected packages as .mcpack for creating backups or easy sharing.">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xEDE2;"
                                      FontSize="18"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="Export"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Delete Selection Button -->
                    <Button x:Name="DeleteButton"
                            Click="DeleteButton_Click"
                            Grid.Row="0"
                            Grid.Column="4"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="0,6,6,0"
                            BorderThickness="0"
                            IsTextScaleFactorEnabled="False"
                            ToolTipService.ToolTip="Physically delete the files of the selected packages from game's data directory.
                            &#x0a;&#x0a;WARNING FOR ADVANCED USERS: This functionality walks up to the parent directory of the selected resource pack, as to not leave orphaned empty folders behind, if you keep other files inside a resource pack, or keep multiple resource packs inside one folder for whatever the reason, steer clear of this button.">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE74D;"
                                      FontSize="18"
                                      Margin="0,0,2,0"
                                      VerticalAlignment="Center" />
                            <TextBlock Text=""
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- ============================================ -->
                    <!-- OVERLAY BORDERS FOR BEVEL VISUALS            -->
                    <!-- ============================================ -->
                    <Grid Grid.Row="0"
                          Grid.Column="0"
                          Grid.RowSpan="5"
                          HorizontalAlignment="Right"
                          Width="3"
                          Margin="0,0,-3,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                                BorderThickness="3,0,0,0" />
                    </Grid>
                    <Grid Grid.Row="0"
                          Grid.Column="2"
                          Grid.RowSpan="5"
                          HorizontalAlignment="Left"
                          Width="3"
                          Margin="-3,0,0,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                                BorderThickness="3,0,0,0" />
                    </Grid>
                    <Grid Grid.Row="0"
                          Grid.Column="2"
                          Grid.RowSpan="5"
                          HorizontalAlignment="Right"
                          Width="3"
                          Margin="0,0,-3,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                                BorderThickness="3,0,0,0" />
                    </Grid>
                    <Grid Grid.Row="0"
                          Grid.Column="4"
                          Grid.RowSpan="5"
                          HorizontalAlignment="Left"
                          Width="3"
                          Margin="-3,0,0,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                                BorderThickness="3,0,0,0" />
                    </Grid>
                </Grid>

                <Grid Grid.Row="4"
                      Margin="8,0,16,16"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Bottom"
                      Height="136"
                      BorderThickness="0"
                      Translation="0,0,33">
                    <Grid.Shadow>
                        <ThemeShadow/>
                    </Grid.Shadow>
                    <Grid.RowDefinitions>
                        <!-- First is button row, second is the divider space between them, so on so forth -->
                        <RowDefinition Height="*" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- ============================================ -->
                    <!-- ROW 1 -->
                    <!-- ============================================ -->

                    <!-- Pack Updater -->
                    <Button x:Name="LaunchPackUpdateButton"
                            Click="LaunchPackUpdateButton_Click"
                            Grid.Row="0"
                            Grid.Column="0"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="6, 0, 0 ,0"
                            BorderThickness="0"
                            IsTextScaleFactorEnabled="False"
                            ToolTipService.ToolTip="See installation information, update availability &amp; news of Vanilla RTX resource packs. Get updates faster, install or simply reinstall each pack.">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xEBD3;"
                                      FontSize="18"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"
                                      x:Name="UpdateVanillaRTXGlyph"
                                      x:FieldModifier="public" />
                            <TextBlock Text="Get latest RTX packs"
                                       VerticalAlignment="Center"
                                       x:Name="UpdateVanillaRTXButtonText"
                                       x:FieldModifier="public" />
                        </StackPanel>
                    </Button>

                    <!--  Lut Manager Button -->
                    <Button x:Name="LaunchLUTManagerButton"
                            Click="LaunchLUTManagerButton_Click"
                            Grid.Row="0"
                            Grid.Column="2"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="0, 6, 0 ,0"
                            BorderThickness="0"
                            IsTextScaleFactorEnabled="False"
                            ToolTipService.ToolTip="Provides simpler, more reliable alternative to BetterRTX that works across all game versions by modifying RTX's default color look up tables.">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE790;"
                                      FontSize="18"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="RTX LUT manager"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- ============================================ -->
                    <!-- ROW 2  -->
                    <!-- ============================================ -->

                    <!-- Alchitex -->
                    <Button x:Name="LaunchAlchitexButton"
                            Click="LaunchAlchitexButton_Click"
                            Grid.Row="2"
                            Grid.Column="0"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="0, 0, 0 ,0"
                            BorderThickness="0"
                            IsTextScaleFactorEnabled="False"
                            ToolTipService.ToolTip="RTX Reactor ">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xF4A5;"
                                      FontSize="18"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"
                                      Opacity="0.75" />
                            <TextBlock Text="RTX Reactor"
                                       VerticalAlignment="Center"
                                       Opacity="0.75" />
                        </StackPanel>
                    </Button>

                    <!-- Better RTX -->
                    <Button x:Name="LaunchBetterRTXManagerButton"
                            Click="LaunchBetterRTXManagerButton_Click"
                            Grid.Row="2"
                            Grid.Column="2"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="0, 0, 0, 0"
                            BorderThickness="0"
                            IsTextScaleFactorEnabled="False"
                            ToolTipService.ToolTip="Manage and install BetterRTX presets.
                            &#x0a;&#x0a;WARNING: It is your responsibility to make sure your game and BetterRTX are up-to-date, before you inject presets into your game, otherwise it could cause issues, in such cases, revert back to Default RTX preset which is backed up from YOUR latest game installation files upon installing your first preset.">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xEABC;"
                                      FontSize="18"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="BetterRTX manager"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- ============================================ -->
                    <!-- ROW 3 -->
                    <!-- ============================================ -->

                    <!-- Launch Button -->
                    <Button x:Name="LaunchMinecraftButton"
                            Click="LaunchMinecraftButton_Click"
                            BorderThickness="0"
                            Grid.Row="6"
                            Grid.Column="0"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="0,0,0,6"
                            IsTextScaleFactorEnabled="False"
                            ToolTipService.ToolTip="Launches Minecraft or Minecraft Preview with ray tracing pre-enabled to avoid issues. Additionally disables VSync for better performance and enables in-game graphics mode switching.
                            &#x0a;&#x0a;FOR ADVANCED USERS: Holding shift while pressing this button enables game's VSync instead.">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE78B;"
                                      FontSize="18"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"
                                      x:Name="LaunchButtonFontIcon"/>
                            <TextBlock Text="Launch Minecraft RTX"
                                       VerticalAlignment="Center"
                                       x:Name="LaunchButtonText" />
                        </StackPanel>
                    </Button>

                    <!-- DLSS Swapper -->
                    <Button x:Name="LaunchDLSSSwapperButton"
                            Click="LaunchDLSSSwapperButton_Click"
                            Grid.Row="6"
                            Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="0,0,6,0"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            IsTextScaleFactorEnabled="False"
                            ToolTipService.ToolTip="Import various DLSS versions that you want, and quickly swap between them.">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE81E;"
                                      FontSize="18"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="DLSS swapper"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- ============================================ -->
                    <!-- OVERLAY BORDERS FOR VISUAL SPLITS -->
                    <!-- ============================================ -->

                    <!-- TOP HORIZONTAL DIVIDER (dark line under row 1) -->
                    <Grid Grid.Row="0"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          VerticalAlignment="Bottom"
                          Height="3"
                          Margin="0,0,0,-3"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                                BorderThickness="0,0,0,3" />
                    </Grid>

                    <!-- MIDDLE TOP HORIZONTAL DIVIDER (bright line above row 2) -->
                    <Grid Grid.Row="2"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          VerticalAlignment="Top"
                          Height="3"
                          Margin="0,-3,0,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                                BorderThickness="0,3,0,0" />
                    </Grid>

                    <!-- MIDDLE BOTTOM HORIZONTAL DIVIDER (dark line under row 2) -->
                    <Grid Grid.Row="2"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          VerticalAlignment="Bottom"
                          Height="3"
                          Margin="0,0,0,-3"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                                BorderThickness="0,0,0,3" />
                    </Grid>

                    <!-- BOTTOM HORIZONTAL DIVIDER (bright line above row 3) -->
                    <Grid Grid.Row="4"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          VerticalAlignment="Top"
                          Height="3"
                          Margin="0,-3,0,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                                BorderThickness="0,3,0,0" />
                    </Grid>

                    <!-- LEFT VERTICAL DIVIDER (dark line on right edge of left column) -->
                    <Grid Grid.Row="0"
                          Grid.Column="0"
                          Grid.RowSpan="5"
                          HorizontalAlignment="Right"
                          Width="3"
                          Margin="0,0,-3,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonDarkBorderColor}"
                                BorderThickness="3,0,0,0" />
                    </Grid>

                    <!-- RIGHT VERTICAL DIVIDER (bright line on left edge of right column) -->
                    <Grid Grid.Row="0"
                          Grid.Column="2"
                          Grid.RowSpan="5"
                          HorizontalAlignment="Left"
                          Width="3"
                          Margin="-3,0,0,0"
                          IsHitTestVisible="False">
                        <Rectangle Fill="{ThemeResource ButtonBackgroundThemeBrush}" />
                        <Border BorderBrush="{ThemeResource FakeSplitButtonBrightBorderColor}"
                                BorderThickness="3,0,0,0" />
                    </Grid>

                    <!-- FUCKY CORRECTION PIXEL (Top Cross) -->
                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Width="3"
                            Height="3"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="{ThemeResource IntersectionNeutralizerBrush}"
                            Opacity="1.0"
                            IsHitTestVisible="False" />

                    <!-- FUCKY CORRECTION PIXEL (Bottom Cross) -->
                    <Border Grid.Row="3"
                            Grid.Column="1"
                            Width="3"
                            Height="3"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="{ThemeResource IntersectionNeutralizerBrush}"
                            Opacity="1.0"
                            IsHitTestVisible="False" />

                </Grid>
            </Grid>
        </Grid>
        
        
        
        
    </Grid>
</Window>
